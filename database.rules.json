{
  "rules": {
    ".read": false,
    ".write": false,
    "presence": {
      "$eventId": {
        ".read": true,
        "$participantId": {
          ".write": true,
          ".validate": "newData.hasChildren(['name', 'lastSeen']) && newData.child('name').isString() && newData.child('name').val().length <= 80"
        }
      }
    }
  }
}
