rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /events/{eventId} {
      // Painting and joining are open only while the event is not finalized.
      function eventOpen() {
        return !('finalized' in get(/databases/$(database)/documents/events/$(eventId)).data)
               || get(/databases/$(database)/documents/events/$(eventId)).data.finalized == null;
      }

      allow read: if true;
      allow create: if false;
      // Host: full update (finalize/reopen, ownerEmail). Anyone signed in
      // (incl. anonymous): may bump ONLY the visit timestamp used by GC.
      allow update: if request.auth.uid == resource.data.ownerUid
                    || (request.auth != null
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastVisitedAt']));
      allow delete: if request.auth.uid == resource.data.ownerUid;

      match /participants/{participantId} {
        allow read: if true;
        allow create: if false;
        allow update: if request.auth.uid == resource.data.uid && eventOpen();
        allow delete: if request.auth.uid == resource.data.uid;
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null
                      && request.resource.data.uid == request.auth.uid
                      && request.resource.data.text is string
                      && request.resource.data.text.size() > 0
                      && request.resource.data.text.size() <= 500
                      && request.resource.data.authorName is string
                      && request.resource.data.authorName.size() > 0
                      && request.resource.data.authorName.size() <= 80;
        allow update: if false;
        allow delete: if request.auth.uid == resource.data.uid
                      || request.auth.uid == get(/databases/$(database)/documents/events/$(eventId)).data.ownerUid;
      }

      match /secrets/{participantId} {
        allow read, write: if false;
      }
    }
  }
}
